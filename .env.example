APP_ENV=local
API_BASE_URL=https://your-public-url.ngrok-free.app
LOCAL_PUBLISH_DOMAIN=your-public-url.ngrok-free.app
VERIFY_TOKEN=hello123
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_GRAPH_API_VERSION=v24.0
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
TIMEZONE=Asia/Tokyo

APP_DB_HOST=db
APP_DB_NAME=app
APP_DB_USERNAME=app_user
APP_DB_PASSWORD=app_pass
APP_DB_PORT=5432
APP_DB_SSLMODE=disable

# Development / shadow database (required for Atlas schema management)
APP_ATLAS_DEV_DB_HOST=db_dev
APP_ATLAS_DEV_DB_NAME=app
APP_ATLAS_DEV_DB_USERNAME=app_user
APP_ATLAS_DEV_DB_PASSWORD=app_pass
APP_ATLAS_DEV_DB_PORT=5432
APP_ATLAS_DEV_DB_SSLMODE=disable

# For LangGraph checkpointer (Short-term memory)
CP_CONVERSATION_DB_HOST=db
CP_CONVERSATION_DB_NAME=cp_conversation
CP_CONVERSATION_DB_USERNAME=app_user
CP_CONVERSATION_DB_PASSWORD=app_pass
CP_CONVERSATION_DB_PORT=5432
CP_CONVERSATION_DB_SSLMODE=disable
